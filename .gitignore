# ---- Raw data (re-downloaded by run_pipeline.R --gee; do not commit ~12 GB) ----
03_datasets/raw/*
!03_datasets/raw/.gitkeep

# ---- R session / IDE ----
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# ---- Quarto build artifacts (regenerated on render) ----
.quarto/
**/.quarto/
**/*_cache/
**/*_files/
04_presentation/presentation_files/
04_presentation/presentation_cache/

# Exception: these interactive figures' *_files/ dependencies must ship so the
# presentation's Data Sources map and Country Trends plot render on the website.
# (bpcr_interactive needs no *_files/, so it stays ignored.)
!04_outputs/figures/data_sources_map_files/
!04_outputs/figures/data_sources_map_files/**
!04_outputs/figures/desc_trend_regional_files/
!04_outputs/figures/desc_trend_regional_files/**

# ---- OS / editor cruft ----
.DS_Store
**/.DS_Store
*~
.luarc.json

# ---- Credentials: NEVER commit. The *.enc blobs are decryptable with the
#      in-repo password, so on a public repo they would expose GEE/Drive access.
#      Keep them local only. ----
03_datasets/config/*.enc
03_datasets/config/*.json
03_datasets/config/ee_credentials

# ---- Copyrighted reference PDFs: do not redistribute on a public repo ----
01_literature/*.pdf
00_notes/*.pdf

# ---- LaTeX build artifacts in 05_paper (regenerated by `quarto render`) ----
05_paper/*.tex
05_paper/*.spl
05_paper/elsarticle.cls
05_paper/elsarticle-harv.bst
05_paper/placeholder.png

# ---- GHSL extraction cache for the German Kreis supplementary (local speed-up;
#      delete to force a fresh GEE pull under --gee) ----
03_datasets/processed/_deu_ghsl_raw.rds

# ---- Temp ----
tmp/
*.log
